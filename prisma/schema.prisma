generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Style {
  id                String   @id @default(cuid())
  name              String
  description       String?
  promptText        String
  referenceImageUrl String?
  sampleImageUrls   String[]
  isPredefined      Boolean  @default(false)
  createdAt         DateTime @default(now())
  posts             GeneratedPost[]
}

model ContentSource {
  id        String        @id @default(cuid())
  title     String
  rawText   String
  createdAt DateTime      @default(now())
  ideas     ContentIdea[]
}

model ContentIdea {
  id          String        @id @default(cuid())
  sourceId    String
  source      ContentSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  ideaText    String
  contentType String
  format      String
  slideCount  Int           @default(1)
  isSaved     Boolean       @default(false)
  createdAt   DateTime      @default(now())
  posts       GeneratedPost[]
}

model BrandSettings {
  id        String   @id @default(cuid())
  brandName String
  colors    String[]
  tagline   String?
  logoUrl   String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model GeneratedPost {
  id            String         @id @default(cuid())
  styleId       String?
  style         Style?         @relation(fields: [styleId], references: [id])
  contentIdeaId String?
  contentIdea   ContentIdea?   @relation(fields: [contentIdeaId], references: [id])
  prompt        String
  format        String
  aspectRatio   String
  model         String
  includeLogo   Boolean        @default(false)
  status        String         @default("pending")
  description   String?
  createdAt     DateTime       @default(now())
  images        GeneratedImage[]
}

model GeneratedImage {
  id                 String        @id @default(cuid())
  postId             String
  post               GeneratedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  slideNumber        Int
  cloudinaryUrl      String
  cloudinaryPublicId String
  createdAt          DateTime      @default(now())
}
